# Скопировать в .env и заполнить перед запуском
# cp .env.example .env

# PostgreSQL
POSTGRES_DB=controlling
POSTGRES_USER=controlling_user
POSTGRES_PASSWORD=сюда_сильный_пароль

# PostgREST JWT (минимум 32 символа, случайная строка)
# Сгенерировать: openssl rand -base64 48 | tr -d '/+=\n' | head -c 48
JWT_SECRET=сюда_jwt_secret
